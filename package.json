{
  "name": "galaxy-defender",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "node scripts/serve-static.mjs",
    "dev": "npm start",
    "build": "node scripts/prepare-static.mjs && node scripts/verify-static-assets.mjs",
    "vercel-build": "npm run build",
    "preview": "node scripts/serve-static.mjs dist 4173",
    "check": "node --check src/game.js && node --check src/core/router.js",
    "audit:assets": "node scripts/audit-assets.mjs",
    "verify:deploy": "node scripts/verify-static-assets.mjs",
    "docker:build": "docker build -t galaxy-defender:latest .",
    "docker:run": "docker run --rm -p 8080:80 galaxy-defender:latest",
    "k8s:apply": "kubectl apply -f k8s/galaxy-defender.yaml",
    "k8s:delete": "kubectl delete -f k8s/galaxy-defender.yaml",
    "clean": "node scripts/clean.mjs"
  },
  "dependencies": {},
  "devDependencies": {}
}
